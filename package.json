{
  "name": "news-feishu-bot",
  "version": "1.0.0",
  "description": "自动抓取新闻、分类、生成图片并通过飞书推送的机器人",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "test": "node src/main.js --test",
    "once": "node src/main.js --once",
    "crawl": "node src/news_crawler.js",
    "classify": "node src/news_classifier.js",
    "generate": "node src/image_generator.js",
    "feishu": "node src/feishu_sender.js",
    "setup": "chmod +x scripts/setup.sh && ./scripts/setup.sh",
    "dev": "nodemon src/main.js"
  },
  "dependencies": {
    "@cloudbase/node-sdk": "^3.18.0",
    "axios": "^1.6.0",
    "canvas": "^2.11.2",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "form-data": "^4.0.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": "24.x"
  },
  "keywords": [
    "news",
    "feishu",
    "crawler",
    "ai"
  ],
  "author": "",
  "license": "MIT"
}
